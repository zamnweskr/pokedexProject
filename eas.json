{
  "cli": {
    "version": ">= 18.1.0",
    "appVersionSource": "remote",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "prebuildCommand": "mkdir -p .expo/web && npx expo prebuild --non-interactive"
    }
  },
  "submit": {
    "production": {}
  }
}